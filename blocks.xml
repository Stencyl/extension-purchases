<?xml version="1.0" encoding="UTF-8"?>
<palette>
    
    <block tag="mobile-purchase-id"
           code="productID"
           type="normal"
           returns="text"
           category="mobile"
           hidden="true"
           helpURL="event-mobile">
        <context>
            <requiredContext type="has" value="productID:String" />
        </context>
    </block>

    <block tag="event-mobile-purchases"
           type="event"
           returns="void"
           category="events"
           helpURL="event-mobile">
        <code>
            <event-def params="productID:String" innercode="#1" listener="addPurchaseListener(#0, ${eventRef});" />
        </code>
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@event.mobile.purchases.ready" code="200" />
                    <c text="@event.mobile.purchases.success" code="201" />
                    <c text="@event.mobile.purchases.fail" code="202" />
                    <c text="@event.mobile.purchases.restore" code="203" />
                    <c text="@event.mobile.purchases.cancel" code="204" />
                    <c text="@event.mobile.purchases.request" code="205" />
                    <c text="@event.mobile.purchases.validate" code="206" />
                </choices>
            </dropdown>
            <code-block order="1" />
            <attached-block order="2" tag="mobile-purchase-id" />
        </fields>
        <context>
            <innerContext type="class" value="com.stencyl.behavior.Script" />
            <innerContext type="has" value="productID:String" />
        </context>
    </block>

    <block tag="iap-buy-use"
           code="com.stencyl.purchases.Purchases.~(~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@buy" code="buy" />
                    <c text="@use" code="use" />
                </choices>
            </dropdown>
            <text order="1" />
        </fields>
    </block>

    <block tag="iap-free-unmanaged"
           code="com.stencyl.purchases.Purchases.consume(~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
        </fields>
    </block>

    <block tag="iap-get-quantity"
           code="com.stencyl.purchases.Purchases.getQuantity(~)"
           type="normal"
           returns="int"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
        </fields>
    </block>

    <block tag="iap-loaded"
           code="com.stencyl.purchases.Purchases.canBuy()"
           type="normal"
           returns="boolean"
           category="mobile"
           helpURL="game-mobile">
    </block>

    <block tag="iap-purchased"
           code="com.stencyl.purchases.Purchases.hasBought(~)"
           type="normal"
           returns="boolean"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
        </fields>
    </block>

    <block tag="iap-request-info"
           code="com.stencyl.purchases.Purchases.requestProductInfo([~]);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
        </fields>
    </block>

    <block tag="iap-restore"
           code="com.stencyl.purchases.Purchases.restorePurchases();"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
    </block>

    <block tag="iap-title-desc-price"
           code="com.stencyl.purchases.Purchases.get~(~)"
           type="normal"
           returns="text"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@title" code="Title" />
                    <c text="@desc" code="Description" />
                    <c text="@price" code="Price" />
                </choices>
            </dropdown>
            <text order="1" />
        </fields>
    </block>

    <block tag="iap-validated"
           code="com.stencyl.purchases.Purchases.validateReceipt(~, ~, ~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <object order="0"></object>
            <text order="1"></text>
            <dropdown order="2">
                <choices>
                    <c text="@production" code="true"></c>
                    <c text="@sandbox" code="false"></c>
                </choices>
            </dropdown>
        </fields>
    </block>
    
</palette>